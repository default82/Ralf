#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(cd "${SCRIPT_DIR}/.." && pwd)
TARGET_SCRIPT="${REPO_ROOT}/automation/ralf/rlwrap/ralf-ai.sh"

if [[ ! -x "${TARGET_SCRIPT}" ]]; then
  echo "${0##*/}: missing helper script at ${TARGET_SCRIPT}" >&2
  exit 1
fi

exec "${TARGET_SCRIPT}" "$@"
