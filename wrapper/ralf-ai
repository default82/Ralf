#!/usr/bin/env bash
set -euo pipefail

show_help() {
  cat <<'HELP'
ralf-ai - Remote Autonomous LXC Friend

Usage: ralf-ai [OPTIONS]

Options:
  --help       Show this help message and exit
  --version    Print the CLI version
HELP
}

if [[ $# -eq 0 ]]; then
  echo "ralf-ai: no command specified" >&2
  show_help >&2
  exit 1
fi

case "$1" in
  --help|-h)
    show_help
    ;;
  --version)
    echo "ralf-ai version 0.1.0"
    ;;
  *)
    echo "ralf-ai: unknown command '$1'" >&2
    show_help >&2
    exit 2
    ;;
esac
