{
  "name": "Matrix Incident Bridge",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "webhook/matrix/incident",
        "respondWith": "json",
        "responseBody": "{\"status\":\"accepted\"}",
        "options": {
          "responseCode": 202,
          "allowUnauthorizedCerts": false
        }
      },
      "id": "IncidentWebhook",
      "name": "Incident Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        260,
        300
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "roomId": "={{$json[\"matrix_room_id\"] || $env.MATRIX_ROOM_ID}}",
        "text": "={{$json[\"body\"] || ($json[\"event\"] && $json[\"event\"].description) || 'Incident received'}}",
        "accessToken": "={{$json[\"matrix_access_token\"] || $env.MATRIX_ACCESS_TOKEN}}",
        "baseUrl": "={{$json[\"matrix_base_url\"] || $env.MATRIX_BASE_URL}}"
      },
      "id": "MatrixDispatch",
      "name": "Matrix Send Message",
      "type": "n8n-nodes-base.matrix",
      "typeVersion": 1,
      "position": [
        560,
        300
      ]
    }
  ],
  "connections": {
    "Incident Webhook": {
      "main": [
        [
          {
            "node": "Matrix Send Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "Europe/Berlin",
    "executionOrder": "v1"
  },
  "staticData": null,
  "pinData": null,
  "id": "MatrixIncidentBridge",
  "meta": {
    "templateCredsSetupCompleted": true
  },
  "version": 2
}
