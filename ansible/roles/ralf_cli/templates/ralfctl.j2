#!/usr/bin/env bash
set -euo pipefail

LOG_TAG=${LOG_TAG:-ralfctl}
LOGGER_BIN=$(command -v logger || true)
ROOT_DIR="{{ ralf_cli_make_path }}"
MAKE_BIN=${MAKE_BIN:-make}

log() {
  local level=$1; shift
  local message=$*
  [[ -n ${LOGGER_BIN:-} ]] && ${LOGGER_BIN} -t "${LOG_TAG}" "${level}: ${message}" || true
  printf '%s: %s\n' "${level}" "${message}" >&2
}

usage() {
  cat <<USAGE
Usage: ralfctl <command>

Commands:
  lint            Run make lint
  validate        Run make validate
  preflight       Run make preflight
  install         Run make install (grafischer Installer)
  plan            Run make plan
  build           Run make plan && make apply
  apply           Run make apply
  smoke           Run make smoke
  backup-check    Run make backup-check
USAGE
}

run_make() {
  local target=$1
  shift || true
  log INFO "Executing make ${target}"
  "${MAKE_BIN}" -C "${ROOT_DIR}" "${target}" "$@"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  local cmd=$1; shift

  case "${cmd}" in
    lint|validate|preflight|install|plan|apply|smoke|backup-check)
      run_make "${cmd}" "$@"
      ;;
    build)
      run_make plan "$@"
      run_make apply "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      log ERROR "Unknown command: ${cmd}"
      usage
      exit 1
      ;;
  esac
}

main "$@"
