location:
  source_directories:
{% for path in borgmatic_sources %}
    - {{ path }}
{% endfor %}
  repositories:
    - {{ borgmatic_repository }}
  exclude_patterns: []
retention:
  keep_daily: {{ borgmatic_retention.keep_daily }}
  keep_weekly: {{ borgmatic_retention.keep_weekly }}
  keep_monthly: {{ borgmatic_retention.keep_monthly }}
consistency:
  checks:
    - repository
    - archives
hooks:
  before_backup:
{% for hook in borgmatic_hooks_pre_backup %}
    - {{ hook }}
{% endfor %}
  after_backup:
{% for hook in borgmatic_hooks_post_backup %}
    - {{ hook }}
{% endfor %}
  on_error: []
output:
  color: auto
  log_file: {{ common_log_dir }}/borgmatic.log
