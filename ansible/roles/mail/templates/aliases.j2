# Managed by Ansible - /etc/aliases

root: {{ mail_root_alias }}
{% for alias in mail_aliases | default([]) %}
{% set alias_name = alias.name | default(alias.get('name')) %}
{% set alias_target = alias.target | default(alias.get('target')) %}
{% if alias_name and alias_target and alias_name != 'root' %}
{{ alias_name }}: {{ alias_target }}
{% endif %}
{% endfor %}
