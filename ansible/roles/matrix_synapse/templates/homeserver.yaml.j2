server_name: {{ matrix_synapse_server_name }}
public_baseurl: {{ matrix_synapse_public_baseurl }}
report_stats: false

listeners:
  - port: 8008
    bind_addresses: ['0.0.0.0']
    type: http
    tls: false
    x_forwarded: true
    resources:
      - names: [client, federation]
        compress: false

log_config: {{ matrix_synapse_log_config }}
media_store_path: {{ matrix_synapse_media_dir }}

registration_shared_secret: {{ lookup('file', matrix_synapse_registration_shared_secret_file, errors='ignore') | default('CHANGE_ME', true) }}
macaroon_secret_key: {{ lookup('file', matrix_synapse_macaroon_secret_file, errors='ignore') | default('CHANGE_ME', true) }}

allow_guest_access: false
enable_registration: false

user_directory:
  enabled: true

password_config:
  enabled: true

app_service_config_files: []

federation_domain_whitelist: []

trusted_key_servers:
  - server_name: matrix.org

database:
  name: psycopg2
  args:
    user: {{ matrix_synapse_postgres_user }}
    password: {{ lookup('file', matrix_synapse_postgres_password_file, errors='ignore') | default('CHANGE_ME', true) }}
    database: {{ matrix_synapse_postgres_db }}
    host: {{ matrix_synapse_postgres_host }}
    port: {{ matrix_synapse_postgres_port }}

{% if matrix_synapse_turn.enabled %}
turn_uris:
{%- for uri in matrix_synapse_turn.uris %}
  - {{ uri }}
{%- endfor %}
turn_shared_secret: {{ lookup('file', matrix_synapse_turn.shared_secret_file, errors='ignore') | default('CHANGE_ME', true) }}
{% endif %}
