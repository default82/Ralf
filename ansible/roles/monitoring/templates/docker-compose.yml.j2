#jinja2: lstrip_blocks: True
version: "3.9"

services:
  prometheus:
    image: "{{ monitoring_prometheus_image }}"
    user: "{{ monitoring_prometheus_container_user }}"
    restart: unless-stopped
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ monitoring_prometheus_retention_time }}"
      - "--web.enable-lifecycle"
    volumes:
      - "{{ monitoring_prometheus_config_dir }}/prometheus.yml:/etc/prometheus/prometheus.yml:ro"
      - "{{ monitoring_prometheus_rules_dir }}:/etc/prometheus/rules"
      - "{{ monitoring_prometheus_data_dir }}:/prometheus"
    ports:
      - "{{ monitoring_prometheus_port }}:9090"

  alertmanager:
    image: "{{ monitoring_alertmanager_image }}"
    user: "{{ monitoring_alertmanager_container_user }}"
    restart: unless-stopped
    command:
      - "--config.file=/etc/alertmanager/alertmanager.yml"
    volumes:
      - "{{ monitoring_alertmanager_config_dir }}/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro"
      - "{{ monitoring_alertmanager_data_dir }}:/alertmanager"
    ports:
      - "{{ monitoring_alertmanager_port }}:9093"
    depends_on:
      - prometheus

  grafana:
    image: "{{ monitoring_grafana_image }}"
    user: "{{ monitoring_grafana_container_user }}"
    restart: unless-stopped
    environment:
      GF_SECURITY_ADMIN_USER: "{{ monitoring_grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ monitoring_grafana_admin_password }}"
    volumes:
      - "{{ monitoring_grafana_config_dir }}/grafana.ini:/etc/grafana/grafana.ini:ro"
      - "{{ monitoring_grafana_data_dir }}:/var/lib/grafana"
    ports:
      - "{{ monitoring_grafana_port }}:3000"
    depends_on:
      - prometheus

  node-exporter:
    image: "{{ monitoring_node_exporter_image }}"
    user: "{{ monitoring_node_exporter_container_user }}"
    restart: unless-stopped
    command:
      - "--path.rootfs=/host"
    pid: host
    volumes:
      - "/proc:/host/proc:ro"
      - "/sys:/host/sys:ro"
      - "/:/host:ro"
    ports:
      - "{{ monitoring_node_exporter_port }}:9100"

volumes: {}
