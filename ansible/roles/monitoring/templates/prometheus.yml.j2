#jinja2: lstrip_blocks: True
global:
  scrape_interval: {{ monitoring_prometheus_scrape_interval }}
  evaluation_interval: {{ monitoring_prometheus_evaluation_interval }}

alerting:
  alertmanagers:
    - static_configs:
{% if monitoring_prometheus_alertmanager_targets %}
        - targets:
{% for target in monitoring_prometheus_alertmanager_targets %}
            - "{{ target }}"
{% endfor %}
{% else %}
        - targets: []
{% endif %}

{% if monitoring_prometheus_rule_files %}
rule_files:
{% for rule_file in monitoring_prometheus_rule_files %}
  - "{{ rule_file }}"
{% endfor %}
{% else %}
rule_files: []
{% endif %}

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - "localhost:{{ monitoring_prometheus_port }}"
  - job_name: node-exporter
    static_configs:
{% if monitoring_prometheus_node_exporter_targets %}
      - targets:
{% for target in monitoring_prometheus_node_exporter_targets %}
          - "{{ target }}"
{% endfor %}
{% else %}
      - targets: []
{% endif %}
{% for scrape_config in monitoring_prometheus_additional_scrape_configs %}
  - {{ scrape_config | to_nice_yaml(indent=4) | trim | indent(4, False) }}
{% endfor %}
