#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="{{ vaultwarden_backup_dir }}"
SOURCE_DIR="{{ vaultwarden_data_dir }}"
RETENTION={{ vaultwarden_backup_retention | int }}
TIMESTAMP="$(date +%Y%m%d%H%M%S)"
ARCHIVE_NAME="vaultwarden-${TIMESTAMP}.tar.gz"
TARGET_FILE="${BACKUP_DIR}/${ARCHIVE_NAME}"

mkdir -p "${BACKUP_DIR}"

tar -C "${SOURCE_DIR}" -czf "${TARGET_FILE}" .

# Remove old backups while keeping the newest RETENTION files
if (( RETENTION > 0 )); then
  find "${BACKUP_DIR}" -maxdepth 1 -type f -name 'vaultwarden-*.tar.gz' -printf '%T@ %p\n' \
    | sort -nr \
    | awk 'NR>{{ vaultwarden_backup_retention | int }} {print $2}' \
    | xargs -r rm -f
fi
