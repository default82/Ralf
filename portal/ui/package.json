    "ajv": "8.12.0",
    "ajv-formats": "3.0.1",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "js-yaml": "4.1.0",
    "prettier": "3.6.2",
    "tsx": "4.7.0",
    "typescript": "5.3.3",
    "vitest": "1.2.2"
