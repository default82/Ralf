{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralf.example.com/schemas/service-catalog.json",
  "title": "RALF Service Catalog",
  "description": "Schema definition for services exposed in the RALF portal.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "summary",
      "owner",
      "tier",
      "status"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "minLength": 3,
        "description": "Unique, URL-friendly identifier for the service."
      },
      "name": {
        "type": "string",
        "minLength": 3,
        "description": "Human readable service name."
      },
      "summary": {
        "type": "string",
        "minLength": 10,
        "description": "One sentence summary describing the service purpose."
      },
      "owner": {
        "type": "string",
        "minLength": 3,
        "description": "Primary team or person accountable for the service."
      },
      "tier": {
        "type": "string",
        "enum": [
          "mission-critical",
          "business-critical",
          "internal",
          "experimental"
        ],
        "default": "internal",
        "description": "Business impact tier."
      },
      "status": {
        "type": "string",
        "enum": [
          "operational",
          "degraded",
          "maintenance",
          "outage"
        ],
        "default": "operational",
        "description": "Current lifecycle or availability state."
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 2
        },
        "uniqueItems": true,
        "default": [],
        "description": "Searchable taxonomy entries associated with the service."
      },
      "links": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["title", "url"],
          "additionalProperties": false,
          "properties": {
            "title": {
              "type": "string",
              "minLength": 3,
              "description": "Display name for the link."
            },
            "url": {
              "type": "string",
              "format": "uri",
              "description": "Destination URL."
            },
            "category": {
              "type": "string",
              "minLength": 3,
              "description": "Optional grouping for the link (e.g. runbook, dashboard)."
            }
          }
        },
        "default": [],
        "description": "References to runbooks, dashboards, repositories, and other artefacts."
      }
    }
  }
}
