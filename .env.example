# Authentication configuration for the RALF portal
AUTH_ISSUER_URL=https://sso.example.com/realms/ralf
AUTH_CLIENT_ID=ralf-portal
AUTH_CLIENT_SECRET=changeme
AUTH_SECRET=replace-with-random-string
# Optional: override the provider authorization endpoint if Keycloak/Authelia deviates from the default discovery metadata
# AUTH_AUTHORIZATION_URL=https://sso.example.com/realms/ralf/protocol/openid-connect/auth
# Optional: override default callback URL if running the UI on a non-default host/port
PORTAL_BASE_URL=http://localhost:3000
